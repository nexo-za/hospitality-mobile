ENV_NAME="develop"

# API Configuration
EXPO_PUBLIC_API_URL="https://api.example.com/api"
EXPO_PUBLIC_API_TOKEN="your_api_token_here"
EXPO_PUBLIC_API_USER='your_username_here'
EXPO_PUBLIC_API_PASSWORD='your_password_here'

# Ecentric Payment Integration
EXPO_PUBLIC_ECENTRIC_APP_URL="payment.thumbzup.com"
EXPO_PUBLIC_ECENTRIC_APP_CLASS="payment.thumbzup.com.IntentActivity"
EXPO_PUBLIC_ECENTRIC_IS_SUNMI_DEVICE="true"
EXPO_PUBLIC_ECENTRIC_MERCHANT_ID="your_merchant_id_here"
EXPO_PUBLIC_ECENTRIC_SECRET_KEY="your_secret_key_here"
EXPO_PUBLIC_ECENTRIC_ACCESS_KEY="your_access_key_here"
EXPO_PUBLIC_ECENTRIC_MERCHANT_PHONE="your_phone_number"
EXPO_PUBLIC_ECENTRIC_MERCHANT_STREET="your_street_address"
EXPO_PUBLIC_ECENTRIC_MERCHANT_URL="your_website_url"
EXPO_PUBLIC_ECENTRIC_MERCHANT_SUPPORT_PHONE="your_support_phone"
EXPO_PUBLIC_ECENTRIC_MERCHANT_CITY="your_city"
EXPO_PUBLIC_ECENTRIC_MERCHANT_PROVINCE="your_province_code"
EXPO_PUBLIC_ECENTRIC_MERCHANT_COUNTRY_CODE="ZA"
EXPO_PUBLIC_ECENTRIC_MERCHANT_CURRENCY_CODE="ZAR"
EXPO_PUBLIC_ECENTRIC_MERCHANT_POSTAL_CODE="your_postal_code"
EXPO_PUBLIC_ECENTRIC_RECEIPT_REQUIRED="true"
EXPO_PUBLIC_ECENTRIC_SHOW_TRANSACTION_STATUS="true" 