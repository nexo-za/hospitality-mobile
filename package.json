{
  "name": "nexo",
  "main": "expo-router/entry",
  "version": "1.0006",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "adb-reverse": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:3000 tcp:3000",
    "android": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:3000 tcp:3000 && expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "increment-version": "node ./scripts/increment-version.js",
    "build:apk": "npm run increment-version && npx eas build --platform android --profile preview",
    "build:production": "npm run increment-version && npx eas build --platform android --profile production",
    "postinstall": "node scripts/fix-sunmi-printer.js"
  },
  "jest": {
    "preset": "jest-expo"
  },
